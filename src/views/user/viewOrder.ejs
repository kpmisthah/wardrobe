<%- include('../partials/userPartials/header') %>
  <link rel="stylesheet" href="/css/myaccount.css" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

  <style>
    /* Merged Styles from orders.ejs and viewOrder.ejs */
    :root {
      --primary-color: #1a1a1a;
      --secondary-color: #f8f9fa;
      --accent-color: #3b82f6;
      --danger-color: #ef4444;
      --text-color: #374151;
      --text-muted: #9ca3af;
      --border-color: #e5e7eb;
      --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      --radius: 12px;
      --transition: all 0.3s ease;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #f9fafb;
      color: var(--text-color);
    }

    .dashboard-container {
      display: flex;
      min-height: calc(100vh - 80px);
      max-width: 1600px;
      margin: 0 auto;
      padding: 2rem;
      gap: 2rem;
    }

    /* Sidebar Styling */
    .sidebar {
      width: 280px;
      flex-shrink: 0;
      background: white;
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
      height: fit-content;
      position: sticky;
      top: 100px;
      border: 1px solid var(--border-color);
      z-index: 90;
    }

    .nav-link {
      display: flex;
      align-items: center;
      padding: 0.875rem 1rem;
      color: var(--text-color);
      text-decoration: none;
      border-radius: 8px;
      margin-bottom: 0.25rem;
      font-weight: 500;
      transition: var(--transition);
    }

    .nav-link:hover {
      background-color: var(--secondary-color);
      color: var(--primary-color);
      transform: translateX(4px);
    }

    .nav-link.active {
      background-color: var(--primary-color);
      color: white;
    }

    .nav-link i {
      width: 24px;
      margin-right: 0.75rem;
      text-align: center;
    }

    .nav-link.text-danger:hover {
      background-color: #fef2f2;
      color: var(--danger-color);
    }

    /* Main Content */
    .main-content {
      flex: 1;
      min-width: 0;
    }

    /* View Order Specific Styles */
    .card-custom {
      background: #fff;
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-color);
      margin-bottom: 30px;
      overflow: hidden;
    }

    .card-header-custom {
      padding: 20px 25px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #fff;
    }

    .card-header-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--primary-color);
      margin: 0;
    }

    .card-body-custom {
      padding: 25px;
    }

    /* Timeline */
    .stepper-wrapper {
      display: flex;
      justify-content: space-between;
      position: relative;
      margin-bottom: 20px;
      margin-top: 10px;
    }

    .stepper-wrapper::before {
      content: "";
      position: absolute;
      top: 30px;
      left: 0;
      width: 100%;
      height: 4px;
      background: #e9ecef;
      z-index: 0;
      border-radius: 2px;
    }

    .stepper-item {
      position: relative;
      text-align: center;
      flex: 1;
      z-index: 1;
    }

    .step-counter {
      width: 60px;
      height: 60px;
      margin: 0 auto 15px;
      background: #fff;
      border: 4px solid #e9ecef;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: #ddd;
      transition: all 0.3s ease;
    }

    .step-name {
      font-size: 14px;
      text-transform: uppercase;
      font-weight: 700;
      color: #999;
      letter-spacing: 0.5px;
    }

    .stepper-item.completed .step-counter,
    .stepper-item.active .step-counter {
      border-color: #10b981;
      background: #10b981;
      color: #fff;
      box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
    }

    .stepper-item.completed::after,
    .stepper-item.active::after {
      content: "";
      position: absolute;
      width: 100%;
      height: 4px;
      background: #10b981;
      top: 30px;
      left: -50%;
      z-index: -1;
    }

    .stepper-item:first-child::after {
      content: none;
    }

    .stepper-item.active .step-name {
      color: var(--primary-color);
    }

    .stepper-item.completed .step-name {
      color: #10b981;
    }

    /* Item Row */
    .item-row {
      display: flex;
      align-items: center;
      padding: 20px 0;
      border-bottom: 1px solid #f9f9f9;
      gap: 25px;
      transition: background-color 0.2s;
    }

    .item-row:last-child {
      border-bottom: none;
    }

    .item-row:hover {
      background-color: #fafafa;
    }

    .item-image {
      width: 90px;
      height: 90px;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid #eee;
    }

    .item-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 8px;
      display: block;
      text-decoration: none;
    }

    .item-meta {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin-bottom: 5px;
    }

    .item-price {
      font-size: 1.2rem;
      font-weight: 700;
      color: #333;
    }

    /* Summary */
    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      font-size: 1rem;
      color: #555;
    }

    .summary-total {
      display: flex;
      justify-content: space-between;
      padding-top: 20px;
      margin-top: 10px;
      border-top: 2px dashed #eee;
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--primary-color);
    }

    .btn-action {
      padding: 8px 18px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.9rem;
    }

    @media (max-width: 992px) {
      .dashboard-container {
        flex-direction: column;
        padding: 1rem;
      }

      .sidebar {
        width: 100%;
        position: relative;
        top: 0;
        margin-bottom: 1rem;
      }

      .item-row {
        flex-direction: column;
        align-items: flex-start;
      }

      .item-actions {
        margin-top: 15px;
        width: 100%;
        text-align: left !important;
      }
    }
  </style>

  <div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
      <ul class="nav flex-column" style="list-style: none; padding: 0;">
        <li class="nav-item">
          <a class="nav-link" href="/myaccount">
            <i class="fas fa-tachometer-alt"></i> Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/orders">
            <i class="fas fa-shopping-bag"></i> Orders
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/updateProfile">
            <i class="fas fa-user-edit"></i> Profile
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/wallet">
            <i class="fas fa-wallet"></i> Wallet
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/wishlist">
            <i class="fas fa-heart"></i> Wishlist
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/getAddress">
            <i class="fas fa-map-marker-alt"></i> Addresses
          </a>
        </li>
        <li style="margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1rem;">
          <a class="nav-link text-danger" href="/logout">
            <i class="fas fa-sign-out-alt"></i> Logout
          </a>
        </li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Top Header -->
      <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom"
        style="background: #fff; padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
        <div>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
              <li class="breadcrumb-item"><a href="/orders" class="text-decoration-none text-muted">Orders</a></li>
              <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
          </nav>
          <h1 class="h2 fw-bold m-0" style="color: var(--primary-color);">Order Details</h1>
        </div>
        <div>
          <% if (order.paymentStatus==='Success' ) { %>
            <button class="btn btn-outline-dark btn-action me-2" id="downloadInvoices">
              <i class="fas fa-file-invoice me-2"></i>Invoice
            </button>
            <% } %>
              <input type="hidden" name="orderId" value="<%=order.orderId%>">
        </div>
      </div>

      <!-- Major Info & Timeline -->
      <div class="card card-custom">
        <div class="card-body card-body-custom">
          <div class="row mb-5">
            <div class="col-md-6">
              <h6 class="text-secondary text-uppercase small fw-bold ls-1 mb-1">Order ID</h6>
              <h3 class="mb-0 fw-bold" style="color: var(--primary-color);">#<%= order.orderId %>
              </h3>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
              <h6 class="text-secondary text-uppercase small fw-bold ls-1 mb-1">Placed On</h6>
              <h4 class="mb-0 text-dark">
                <%= new Date(order.createdAt).toLocaleDateString(undefined, { weekday: 'long' , year: 'numeric' ,
                  month: 'long' , day: 'numeric' }) %>
              </h4>
            </div>
          </div>

          <!-- Status Timeline -->
          <% const steps=['Pending', 'Shipped' , 'Delivered' ]; const currentStatus=order.status; let
            progressIndex=steps.indexOf(currentStatus); if(currentStatus==='Completed' || currentStatus==='Returned' )
            progressIndex=2; if(currentStatus==='Canceled' ) progressIndex=-1; %>

            <% if(currentStatus==='Canceled' ) { %>
              <div class="alert alert-danger d-flex align-items-center justify-content-center p-4 rounded-3">
                <i class="fas fa-ban fa-2x me-3"></i>
                <div>
                  <h4 class="alert-heading fw-bold mb-1">Order Canceled</h4>
                  <p class="mb-0">This order has been canceled and will not be delivered.</p>
                </div>
              </div>
              <% } else { %>
                <div class="stepper-wrapper px-md-5">
                  <div
                    class="stepper-item <%= progressIndex >= 0 ? 'active' : '' %> <%= progressIndex > 0 ? 'completed' : '' %>">
                    <div class="step-counter"><i class="fas fa-clipboard-check"></i></div>
                    <div class="step-name">Order Placed</div>
                  </div>
                  <div
                    class="stepper-item <%= progressIndex >= 1 ? 'active' : '' %> <%= progressIndex > 1 ? 'completed' : '' %>">
                    <div class="step-counter"><i class="fas fa-shipping-fast"></i></div>
                    <div class="step-name">Shipped</div>
                  </div>
                  <div class="stepper-item <%= progressIndex >= 2 ? 'active' : '' %>">
                    <div class="step-counter"><i class="fas fa-box-open"></i></div>
                    <div class="step-name">Delivered</div>
                  </div>
                </div>
                <% if (order.paymentStatus==='Pending' && order.paymentMethod==='razorpay' && order.status !=='Canceled'
                  ) { %>
                  <div class="text-center mt-4">
                    <button class="btn btn-success btn-lg px-5 py-3 fw-bold shadow-sm"
                      onclick="retryPayment('<%= order.paymentMethod %>', '<%= order.finalAmount || order.totalPrice %>', '<%= order._id %>')">
                      <i class="fas fa-redo-alt me-2"></i> Retry Payment Now
                    </button>
                    <p class="text-muted small mt-2">Your payment is pending. Click above to complete your order.</p>
                  </div>
                  <% } %>
                    <% } %>
        </div>
      </div>

      <div class="row">
        <!-- Items list -->
        <div class="col-lg-8">
          <div class="card card-custom">
            <div class="card-header card-header-custom">
              <h5 class="card-header-title">Items in Your Order</h5>
              <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                <%= order.orderedItems.length %> Items
              </span>
            </div>
            <div class="card-body card-body-custom pt-0">
              <% order.orderedItems.forEach((item)=> { %>
                <div class="item-row">
                  <% if (item.product && item.product.productImage && item.product.productImage.length> 0) { %>
                    <img src="/uploads/product-images/<%= item.product.productImage[0] %>" class="item-image"
                      alt="Product">
                    <% } else { %>
                      <div class="item-image d-flex align-items-center justify-content-center bg-light text-muted">No
                        Img</div>
                      <% } %>

                        <div class="flex-grow-1">
                          <% if (item.product) { %>
                            <a href="/productDetails?id=<%= item.product._id %>" class="item-title">
                              <%= item.product.name %>
                            </a>
                            <% } else { %>
                              <span class="item-title" style="cursor:default;">Unknown Product</span>
                              <% } %>
                                <div class="d-flex flex-wrap gap-3">
                                  <span class="item-meta">Size: <strong class="text-dark">
                                      <%= item.size %>
                                    </strong></span>
                                  <span class="item-meta">Qty: <strong class="text-dark">
                                      <%= item.quantity %>
                                    </strong></span>
                                </div>
                                <div class="item-price mt-2">₹<%= item.price %>
                                </div>
                        </div>

                        <div class="item-actions text-end" style="min-width: 140px;">
                          <% if (item.cancelStatus==='canceled' ) { %>
                            <button class="btn btn-outline-danger btn-action w-100" disabled
                              style="opacity: 0.6; cursor: not-allowed;"><i class="fas fa-ban me-1"></i>
                              Canceled</button>
                            <% } else if (item.returnStatus==='Approved' ) { %>
                              <button class="btn btn-outline-success btn-action w-100" disabled style="opacity: 0.8;"><i
                                  class="fas fa-check me-1"></i> Returned</button>
                              <% } else if ((order.status==='Pending' || order.status==='Shipped' ) &&
                                order.paymentStatus !=='Failed' ) { %>
                                <button id="cancel-button-<%= item._id %>"
                                  class="btn btn-outline-danger btn-action w-100"
                                  onclick="cancel('<%= order.orderId %>', '<%= item._id %>')">
                                  Cancel Item
                                </button>
                                <% } else if ((order.status==='Delivered' || order.status==='Completed' ) &&
                                  item.returnStatus==='Not Requested' ) { %>
                                  <button class="btn btn-outline-dark btn-action w-100"
                                    onclick="returnOrder('<%= item._id %>')">
                                    Return Item
                                  </button>
                                  <% } else if (item.returnStatus !=='Not Requested' ) { %>
                                    <span class="badge bg-warning text-dark px-3 py-2">
                                      <%= item.returnStatus %>
                                    </span>
                                    <% } %>
                        </div>
                </div>
                <% }) %>
            </div>
          </div>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">
          <!-- Order Summary -->
          <div class="card card-custom">
            <div class="card-header card-header-custom">
              <h5 class="card-header-title">Payment Summary</h5>
            </div>
            <div class="card-body card-body-custom">
              <div class="summary-row">
                <span>Item Total</span>
                <span class="fw-bold">₹<%= order.totalPrice %></span>
              </div>
              <div class="summary-row">
                <span>Discount</span>
                <span class="text-success">- ₹<%= order.discount %></span>
              </div>
              <div class="summary-row">
                <span>Delivery Fee</span>
                <span class="text-success">Free</span>
              </div>
              <div class="summary-total">
                <span>Grand Total</span>
                <span>₹<%= order.finalAmount || order.totalPrice %></span>
              </div>
              <div class="mt-3 pt-3 border-top">
                <label class="info-label"
                  style="font-size: 0.85rem; font-weight: 700; color: #888; text-transform: uppercase;">Payment
                  Mode</label>
                <div class="d-flex align-items-center">
                  <span class="badge bg-dark text-white me-2 px-3 py-2 text-uppercase">
                    <%= order.paymentMethod %>
                  </span>
                  <span class="<%= order.paymentStatus === 'Paid' ? 'text-success' : 'text-warning' %> fw-bold">
                    <%= order.paymentStatus %>
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- Shipping Address -->
          <div class="card card-custom">
            <div class="card-header card-header-custom">
              <h5 class="card-header-title">Shipping Address</h5>
            </div>
            <div class="card-body card-body-custom">
              <% if (order.address) { %>
                <div class="address-box" style="line-height: 1.6; color: #444;">
                  <h5 class="fw-bold mb-2">
                    <%= order.address.name %>
                  </h5>
                  <p class="mb-1">
                    <%= order.address.houseNumber %>, <%= order.address.street || '' %>
                  </p>
                  <p class="mb-1">
                    <%= order.address.city %>, <%= order.address.state %>
                  </p>
                  <p class="mb-3 fw-bold">
                    <%= order.address.zipCode %>
                  </p>
                  <div class="d-flex align-items-center text-muted">
                    <i class="fas fa-phone-alt me-2"></i>
                    <span>
                      <%= order.address.phone %>
                    </span>
                  </div>
                </div>
                <% } else { %>
                  <p class="text-muted">No address information available for this order.</p>
                  <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/javascript/viewOrder.js"></script>
  <%- include('../partials/userPartials/footer') %>